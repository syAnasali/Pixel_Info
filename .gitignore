# ====================================================================
# Pixel_Info Image Caption Generator - Customized .gitignore
# ====================================================================

# --------------------------------------------------------------------
# Python & Bytecode
# --------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# --------------------------------------------------------------------
# Virtual Environments
# --------------------------------------------------------------------
venv/
.venv/
env/
ENV/
lib/
lib64/
bin/
include/
share/

# --------------------------------------------------------------------
# IDEs & Editor Configuration
# --------------------------------------------------------------------
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db
desktop.ini

# --------------------------------------------------------------------
# Jupyter Notebooks
# --------------------------------------------------------------------
.ipynb_checkpoints/

# --------------------------------------------------------------------
# Logs & Diagnostics
# --------------------------------------------------------------------
logs/
*.log
runs/
wandb/

# --------------------------------------------------------------------
# Datasets (Exclude raw data but keep folder structure via .gitkeep)
# --------------------------------------------------------------------
data/*
!data/Flickr8k/
data/Flickr8k/*
!data/Flickr8k/.gitkeep

# --------------------------------------------------------------------
# Model Checkpoints (Exclude weights but keep folder structure via .gitkeep)
# --------------------------------------------------------------------
checkpoints/*
!checkpoints/.gitkeep

# --------------------------------------------------------------------
# Generated Outputs & Cache (Exclude generated files but keep .gitkeep)
# --------------------------------------------------------------------
outputs/*
!outputs/.gitkeep

# Exclude serialized pickle files
*.pkl
*.pickle

# --------------------------------------------------------------------
# Testing & Build Artifacts
# --------------------------------------------------------------------
.cache/
.pytest_cache/
.coverage
htmlcov/
build/
dist/
*.egg-info/
